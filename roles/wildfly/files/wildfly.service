[Unit]
Description=WildFly Application Server
After=network.target

[Service]
Type=simple
User=wildfly
Group=wildfly
ExecStart=/usr/share/wildfly/bin/standalone.sh -b 0.0.0.0 -bmanagement 0.0.0.0
Environment=JAVA_HOME=/usr/lib/jvm/java-8-openjdk-amd64
WorkingDirectory=/usr/share/wildfly
Restart=on-failure

[Install]
WantedBy=multi-user.target

[Unit]
Description=WildFly Application Server
After=network.target

[Service]
Type=simple
User=wildfly
Group=wildfly
ExecStart=/usr/share/wildfly/bin/standalone.sh -b 0.0.0.0
Restart=on-failure
Environment=JAVA_HOME=/usr/lib/jvm/java-8-openjdk-amd64
WorkingDirectory=/usr/share/wildfly

[Install]
WantedBy=multi-user.target
